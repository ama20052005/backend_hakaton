# API Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000

# LLaMA (Ollama) Configuration
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=llama3.2:3b
LLAMA_TIMEOUT=120
LLAMA_TEMPERATURE=0.7
LLAMA_MAX_TOKENS=1000

# Data Configuration
DATA_DIR=data/yearly
CSV_ENCODING=utf-8-sig

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO